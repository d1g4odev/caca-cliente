# ─────────────────────────────────────────────────────────────────────────────
# Persistência em PostgreSQL — opcional, mas recomendada.
#
# SEM este arquivo (ou sem DATABASE_URL), o app roda 100% em memória — as
# buscas, leads e estágios do Kanban somem ao reiniciar o servidor (TTL 30min).
# COM ele, tudo fica salvo no banco.
#
# Setup recomendado: PostgreSQL via Docker, rodando no home server (ZimaOS),
# acessado por outras máquinas via Tailscale.
# ─────────────────────────────────────────────────────────────────────────────

# 1) Copie este arquivo:    cp .env.example .env       (no Windows: copy)
# 2) Preencha as variáveis abaixo (instruções nos comentários).
# 3) Reinicie a API.        npm run dev
# 4) Confirme no log:       [db] schema pronto — persistência ATIVADA.

# ── Formato ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=postgresql://captacao_app:TROQUE_AQUI@100.x.y.z:5432/captacao

# ── Onde achar cada valor ──────────────────────────────────────────────────
# HOST     : o IP do seu ZimaOS na Tailscale.
#            Veja em: https://login.tailscale.com/admin/machines
#            (a coluna "Tailscale IP" começa com 100.)
# PORTA    : 5432 é o padrão do PostgreSQL. Só mude se você expôs outra porta
#            no docker-compose / Portainer.
# USUARIO  : se você criou o container com POSTGRES_USER=postgres, use postgres.
#            Recomendado: criar um usuário dedicado "captacao_app".
# SENHA    : a senha que você definiu em POSTGRES_PASSWORD ao subir o container.
# BANCO    : o nome do database. Se você não criou um, use o padrão "postgres"
#            ou crie um chamado "captacao".

# ── Setup do banco no ZimaOS (uma vez só) ──────────────────────────────────
# Se você ainda não criou usuário/banco dedicados, conecte como superuser e rode:
#
#   CREATE USER captacao_app WITH PASSWORD 'troque_isso';
#   CREATE DATABASE captacao OWNER captacao_app;
#   GRANT ALL PRIVILEGES ON DATABASE captacao TO captacao_app;
#
# As TABELAS são criadas automaticamente no primeiro boot do server (ver db.js).

# ── Como testar a conexão antes de subir a API ─────────────────────────────
#   psql "postgresql://captacao_app:SENHA@100.x.y.z:5432/captacao" -c "\l"
# Se listar databases, está OK. Se der "connection refused", é Tailscale/IP/porta.
# Se der "password authentication failed", é usuário/senha.

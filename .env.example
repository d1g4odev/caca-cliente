# ─────────────────────────────────────────────────────────────────────────────
# .env do docker-compose.yml — usado quando você sobe o sistema via Docker
# (ZimaOS, servidor caseiro, VPS, etc.). Para rodar a API/Front diretamente
# fora de Docker (npm run dev), use server/.env.
#
# Como usar:
#   1. cp .env.example .env
#   2. Edite os valores abaixo
#   3. docker compose up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────────────────────────────
# IMPORTANTE: dentro do container do app, o host do Postgres é
# `host.docker.internal` (mapeado automaticamente para o IP do host pelo compose).
# Senha forte (>=20 chars gerados em Bitwarden/1Password). Não commite este arquivo.
DATABASE_URL=postgresql://caca_cliente:TROQUE_AQUI@host.docker.internal:5432/caca_cliente

# ── Comportamento do enriquecimento (opcional) ──────────────────────────────
# ENRICH_CONCURRENCY=2          # leads enriquecidos em paralelo (padrão 2)
# ENRICH_BACKGROUND=true        # false = só enriquece quando o usuário clica
# DATA_PROVIDER=osm             # mock = dados fictícios offline
# ENRICH_PROVIDER=python        # mock = contatos fictícios sem chamar DDG
